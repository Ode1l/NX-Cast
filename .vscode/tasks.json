{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "NX-Cast: Clean",
      "type": "shell",
      "command": "source /opt/devkitpro/switchvars.sh && make clean",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "NX-Cast: Build",
      "type": "shell",
      "command": "source /opt/devkitpro/switchvars.sh && make NXCAST_USE_IMGUI_UI=1 NXCAST_REQUIRE_LIBMPV=1 NXCAST_REQUIRE_DEKO3D=1 NXCAST_REQUIRE_AIRPLAY_ED25519=1 -j4",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "NX-Cast: Build (Trace Media+Input+AirPlay)",
      "type": "shell",
      "command": "source /opt/devkitpro/switchvars.sh && make TRACE_MEDIA=1 TRACE_INPUT=1 TRACE_AIRPLAY=1 NXCAST_USE_IMGUI_UI=1 NXCAST_REQUIRE_LIBMPV=1 NXCAST_REQUIRE_DEKO3D=1 NXCAST_REQUIRE_AIRPLAY_ED25519=1 -j4",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "NX-Cast: Rebuild",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NX-Cast: Clean",
        "NX-Cast: Build"
      ],
      "problemMatcher": []
    },
    {
      "label": "NX-Cast: Rebuild (Trace Media+Input+AirPlay)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NX-Cast: Clean",
        "NX-Cast: Build (Trace Media+Input+AirPlay)"
      ],
      "problemMatcher": []
    },
    {
      "label": "NX-Cast: Package Release",
      "type": "shell",
      "command": "NXCAST_MIN_NRO_SIZE=5000000 ./scripts/package_release.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "NX-Cast: Nxlink Upload",
      "type": "shell",
      "command": "NO_BUILD=1 NXLINK_SERVER=0 ./scripts/run_nxlink.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "NX-Cast: Nxlink Upload + Server",
      "type": "shell",
      "command": "NO_BUILD=1 NXLINK_SERVER=1 ./scripts/run_nxlink.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "NX-Cast: Rebuild + Nxlink Upload",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NX-Cast: Rebuild",
        "NX-Cast: Nxlink Upload"
      ],
      "problemMatcher": []
    },
    {
      "label": "NX-Cast: Rebuild + Nxlink Upload + Server",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NX-Cast: Rebuild",
        "NX-Cast: Nxlink Upload + Server"
      ],
      "problemMatcher": []
    },
    {
      "label": "NX-Cast: Rebuild Trace + Nxlink Upload + Server",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NX-Cast: Rebuild (Trace Media+Input+AirPlay)",
        "NX-Cast: Nxlink Upload + Server"
      ],
      "problemMatcher": []
    },
    {
      "label": "NX-Cast: Rebuild + Package Release",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NX-Cast: Rebuild",
        "NX-Cast: Package Release"
      ],
      "problemMatcher": []
    }
  ]
}
